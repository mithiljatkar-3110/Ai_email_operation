# Application
APP_NAME=AI CRM System
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false

# API
API_V1_PREFIX=/api/v1

# Database (use either DATABASE_URL or individual POSTGRES_* vars)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_crm
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_crm

# SQLAlchemy
DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# LLM (Gemini)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
CLASSIFICATION_RAG_TOP_K=1
CLASSIFICATION_MAX_THREAD_MESSAGES=2
CLASSIFICATION_MAX_THREAD_BODY_CHARS=400
CLASSIFICATION_MAX_EMAIL_BODY_CHARS=1500
CLASSIFICATION_MAX_RAG_CHUNK_CHARS=350
CLASSIFICATION_MAX_OUTPUT_TOKENS=1024

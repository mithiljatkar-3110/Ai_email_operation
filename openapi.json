        "/agent/dry-run/{email_id}": {
            "post": {
                "tags": [
                    "agent"
                ],
                "summary": "Run triage agent in dry-run mode (no DB writes)",
                "description": "Requires the email to already be classified: `category`, `urgency`, and `confidence` must be set (run `POST /api/classify/{email_id}` first). Returns 422 `TRIAGE_NOT_READY` otherwise. No actions are persisted in dry-run.",
                "operationId": "agent_dry_run_agent_dry_run__email_id__post",
                "parameters": [
                    {
                        "name": "email_id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid",
                            "title": "Email Id"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/AgentDryRunResponse"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/agent/execute/{email_id}": {
            "post": {
                "tags": [
                    "agent"
                ],
                "summary": "Run triage agent and persist the final action",
                "description": "Requires the email to already be classified: `category`, `urgency`, and `confidence` must be set (run `POST /api/classify/{email_id}` first). Executes the final action, saves the reasoning trace, and persists an action record in the Actions table.",
                "operationId": "agent_execute_agent_execute__email_id__post",
                "parameters": [
                    {
                        "name": "email_id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid",
                            "title": "Email Id"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/AgentExecuteResponse"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                }
            }
        },

    "components": {
        "schemas": {
            "AgentActivityItem": {
                "properties": {
                    "action_type": {
                        "type": "string",
                        "title": "Action Type"
                    },
                    "email_id": {
                        "type": "string",
                        "title": "Email Id"
                    },
                    "timestamp": {
                        "type": "string",
                        "title": "Timestamp"
                    },
                    "reason": {
                        "type": "string",
                        "title": "Reason"
                    }
                },
                "type": "object",
                "required": [
                    "action_type",
                    "email_id",
                    "timestamp",
                    "reason"
                ],
                "title": "AgentActivityItem"
            },
            "AgentDryRunResponse": {
                "properties": {
                    "final_action": {
                        "type": "string",
                        "title": "Final Action"
                    },
                    "reasoning_trace": {
                        "items": {
                            "$ref": "#/components/schemas/ReasoningStep"
                        },
                        "type": "array",
                        "title": "Reasoning Trace"
                    }
                },
                "type": "object",
                "required": [
                    "final_action"
                ],
                "title": "AgentDryRunResponse"
            },
            "AgentExecuteResponse": {
                "properties": {
                    "final_action": {
                        "type": "string",
                        "title": "Final Action"
                    },
                    "action_saved": {
                        "type": "boolean",
                        "title": "Action Saved"
                    }
                },
                "type": "object",
                "required": [
                    "final_action",
                    "action_saved"
                ],
                "title": "AgentExecuteResponse"
            },
            "ClassificationResult": {
                "properties": {
                    "category": {
                        "type": "string",
                        "enum": [
                            "Complaint",
                            "Inquiry",
                            "Bug Report",
                            "Feature Request",
                            "Compliance",
                            "Legal",
                            "Billing",
                            "Spam",
                            "Internal",
                            "Other"
                        ],
                        "title": "Category"
                    },
                    "sentiment": {
                        "type": "string",
                        "enum": [
                            "Positive",
                            "Neutral",
                            "Negative",
                            "Mixed"
                        ],
                        "title": "Sentiment"
                    },
                    "sentiment_score": {
                        "type": "number",
                        "maximum": 1.0,
                        "minimum": -1.0,
                        "title": "Sentiment Score"
                    },
                    "urgency": {
                        "type": "string",
                        "enum": [
                            "Critical",
                            "High",
                            "Medium",
                            "Low"
                        ],
                        "title": "Urgency"
                    },
                    "requires_human": {
                        "type": "boolean",
                        "title": "Requires Human"
                    },
                    "escalation_reason": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Escalation Reason"
                    },
                    "suggested_reply": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Suggested Reply"
                    },
                    "confidence": {
                        "type": "number",
                        "maximum": 1.0,
                        "minimum": 0.0,
                        "title": "Confidence"
                    },
                    "detected_entities": {
                        "$ref": "#/components/schemas/DetectedEntities"
                    }
                },
                "type": "object",
                "required": [
                    "category",
                    "sentiment",
                    "sentiment_score",
                    "urgency",
                    "requires_human",
                    "confidence"
                ],
                "title": "ClassificationResult"
            },
            "ConfidenceDistribution": {
                "properties": {
                    "high": {
                        "type": "integer",
                        "minimum": 0.0,
                        "title": "High"
                    },
                    "medium": {
                        "type": "integer",
                        "minimum": 0.0,
                        "title": "Medium"
                    },
                    "low": {
                        "type": "integer",
                        "minimum": 0.0,
                        "title": "Low"
                    }
                },
                "type": "object",
                "required": [
                    "high",
                    "medium",
                    "low"
                ],
                "title": "ConfidenceDistribution"
            },
            "DashboardStats": {
                "properties": {
                    "total_emails": {
                        "type": "integer",
                        "minimum": 0.0,
                        "title": "Total Emails"
                    },
                    "total_threads": {
                        "type": "integer",
                        "minimum": 0.0,
                        "title": "Total Threads"
                    },
                    "critical_cases": {
                        "type": "integer",
                        "minimum": 0.0,
                        "title": "Critical Cases"
                    },
                    "escalations": {
                        "type": "integer",
                        "minimum": 0.0,
                        "title": "Escalations"
                    },
                    "spam_detected": {
                        "type": "integer",
                        "minimum": 0.0,
                        "title": "Spam Detected"
                    },
                    "avg_confidence": {
                        "type": "number",
                        "maximum": 1.0,
                        "minimum": 0.0,
                        "title": "Avg Confidence"
                    },
                    "open_threads": {
                        "type": "integer",
                        "minimum": 0.0,
                        "title": "Open Threads"
                    },
                    "resolved_threads": {
                        "type": "integer",
                        "minimum": 0.0,
                        "title": "Resolved Threads"
                    }
                },
                "type": "object",
                "required": [
                    "total_emails",
                    "total_threads",
                    "critical_cases",
                    "escalations",
                    "spam_detected",
                    "avg_confidence",
                    "open_threads",
                    "resolved_threads"
                ],
                "title": "DashboardStats"
            },
            "DetectedEntities": {
                "properties": {
                    "order_ids": {
                        "items": {
                            "type": "string"
                        },
                        "type": "array",
                        "title": "Order Ids"
                    },
                    "ticket_ids": {
                        "items": {
                            "type": "string"
                        },
                        "type": "array",
                        "title": "Ticket Ids"
                    },
                    "monetary_amounts": {
                        "items": {
                            "type": "string"
                        },
                        "type": "array",
                        "title": "Monetary Amounts"
                    },
                    "deadlines": {
                        "items": {
                            "type": "string"
                        },
                        "type": "array",
                        "title": "Deadlines"
                    },
                    "products_mentioned": {
                        "items": {
                            "type": "string"
                        },
                        "type": "array",
                        "title": "Products Mentioned"
                    }
                },
                "type": "object",
                "title": "DetectedEntities"
            },
            "EmailIn": {
                "properties": {
                    "message_id": {
                        "type": "string",
                        "minLength": 1,
                        "title": "Message Id"
                    },
                    "thread_id": {
                        "type": "string",
                        "minLength": 1,
                        "title": "Thread Id"
                    },
                    "sender": {
                        "type": "string",
                        "minLength": 1,
                        "title": "Sender"
                    },
                    "subject": {
                        "type": "string",
                        "title": "Subject"
                    },
                    "body": {
                        "type": "string",
                        "title": "Body"
                    },
                    "timestamp": {
                        "type": "string",
                        "format": "date-time",
                        "title": "Timestamp"
                    }
                },
                "type": "object",
                "required": [
                    "message_id",
                    "thread_id",
                    "sender",
                    "subject",
                    "body",
                    "timestamp"
                ],
                "title": "EmailIn"
            },
            "EmailResponse": {
                "properties": {
                    "job_id": {
                        "type": "string",
                        "format": "uuid",
                        "title": "Job Id"
                    },
                    "status": {
                        "type": "string",
                        "title": "Status",
                        "default": "accepted"
                    }
                },
                "type": "object",
                "required": [
                    "job_id"
                ],
                "title": "EmailResponse"
            },
            "EscalationRate": {
                "properties": {
                    "total_emails": {
                        "type": "integer",
                        "minimum": 0.0,
                        "title": "Total Emails"
                    },
                    "escalated": {
                        "type": "integer",
                        "minimum": 0.0,
                        "title": "Escalated"
                    },
                    "rate": {
                        "type": "number",
                        "maximum": 100.0,
                        "minimum": 0.0,
                        "title": "Rate"
                    }
                },
                "type": "object",
                "required": [
                    "total_emails",
                    "escalated",
                    "rate"
                ],
                "title": "EscalationRate"
            },
            "HTTPValidationError": {
                "properties": {
                    "detail": {
                        "items": {
                            "$ref": "#/components/schemas/ValidationError"
                        },
                        "type": "array",
                        "title": "Detail"
                    }
                },
                "type": "object",
                "title": "HTTPValidationError"
            },
            "InboxItem": {
                "properties": {
                    "email_id": {
                        "type": "string",
                        "title": "Email Id"
                    },
                    "thread_id": {
                        "type": "string",
                        "title": "Thread Id"
                    },
                    "sender": {
                        "type": "string",
                        "title": "Sender"
                    },
                    "subject": {
                        "type": "string",
                        "title": "Subject"
                    },
                    "category": {
                        "type": "string",
                        "title": "Category"
                    },
                    "urgency": {
                        "type": "string",
                        "title": "Urgency"
                    },
                    "status": {
                        "type": "string",
                        "title": "Status"
                    },
                    "confidence": {
                        "anyOf": [
                            {
                                "type": "number",
                                "maximum": 1.0,
                                "minimum": 0.0
